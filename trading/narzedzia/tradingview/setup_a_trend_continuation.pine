//@version=5
// ============================================================
// SETUP A — TREND CONTINUATION (Daniel's trading system)
// ============================================================
// Detektor pullbacku w trendzie + konfluencji:
// - MA50 > MA100 > MA200 (1D bias — long) lub odwrotnie (short)
// - Anchored VWAP (session) jako dynamic S/R
// - Fib retracement 0.5-0.786 (golden pocket)
// - Stoch RSI wychodzi z OS (long) / OB (short)
// - Squeeze Momentum release
// - PA confirmation candle (bullish/bearish engulfing)
//
// OUTPUT: Alert webhook JSON → PHP endpoint → Telegram
// ============================================================

indicator("SETUP A — Trend Continuation [Daniel]", overlay=true, max_bars_back=500)

// ───────── INPUTS ─────────
grp_ma   = "Średnie kroczące"
ma50_len  = input.int(50,  "MA50",  minval=1, group=grp_ma)
ma100_len = input.int(100, "MA100", minval=1, group=grp_ma)
ma200_len = input.int(200, "MA200", minval=1, group=grp_ma)

grp_fib = "Fibonacci"
fib_lookback = input.int(50, "Lookback dla swing low/high", minval=20, maxval=200, group=grp_fib)

grp_srsi = "Stochastic RSI"
srsi_K = input.int(3,  "K smoothing", group=grp_srsi)
srsi_D = input.int(3,  "D smoothing", group=grp_srsi)
srsi_len = input.int(14, "RSI length", group=grp_srsi)
srsi_stoch = input.int(14, "Stoch length", group=grp_srsi)
srsi_os = input.int(20, "OS poziom", group=grp_srsi)
srsi_ob = input.int(80, "OB poziom", group=grp_srsi)

grp_squeeze = "Squeeze Momentum (LazyBear)"
sqz_bb_len  = input.int(20, "BB length", group=grp_squeeze)
sqz_bb_mult = input.float(2.0, "BB mult", group=grp_squeeze)
sqz_kc_len  = input.int(20, "KC length", group=grp_squeeze)
sqz_kc_mult = input.float(1.5, "KC mult", group=grp_squeeze)

grp_alerts = "Alerty"
min_confluences = input.int(4, "Min konfluencji (z 6)", minval=3, maxval=6, group=grp_alerts)
sl_buffer_pct = input.float(0.5, "SL buffer %", step=0.1, group=grp_alerts)
rr_target = input.float(3.0, "R/R target", minval=1.5, group=grp_alerts)

// ───────── MA ─────────
ma50  = ta.sma(close, ma50_len)
ma100 = ta.sma(close, ma100_len)
ma200 = ta.sma(close, ma200_len)

plot(ma50,  "MA50",  color.new(color.yellow, 0), 2)
plot(ma100, "MA100", color.new(color.orange, 0), 2)
plot(ma200, "MA200", color.new(color.red, 0), 2)

bull_ma = ma50 > ma100 and ma100 > ma200
bear_ma = ma50 < ma100 and ma100 < ma200

// ───────── ANCHORED VWAP (session) ─────────
new_session = ta.change(time("D")) != 0
var float vwap_sum = 0.0
var float vol_sum = 0.0
if new_session
    vwap_sum := 0.0
    vol_sum := 0.0
vwap_sum += hlc3 * volume
vol_sum += volume
avwap = vol_sum > 0 ? vwap_sum / vol_sum : close
plot(avwap, "Anchored VWAP (session)", color.new(color.aqua, 0), 2)

above_vwap = close > avwap
below_vwap = close < avwap

// ───────── FIB RETRACEMENT (auto swing) ─────────
swing_high = ta.highest(high, fib_lookback)
swing_low  = ta.lowest(low,   fib_lookback)
fib_range  = swing_high - swing_low

fib_382 = swing_high - fib_range * 0.382
fib_5   = swing_high - fib_range * 0.5
fib_618 = swing_high - fib_range * 0.618
fib_66  = swing_high - fib_range * 0.66
fib_786 = swing_high - fib_range * 0.786

// Cena w strefie golden pocket (long) albo szczytowej (short)
in_long_fib  = close >= fib_786 and close <= fib_5
in_short_fib = close >= fib_5 and close <= fib_382

// ───────── STOCH RSI ─────────
rsi_val = ta.rsi(close, srsi_len)
stoch_rsi = ta.stoch(rsi_val, rsi_val, rsi_val, srsi_stoch)
k = ta.sma(stoch_rsi, srsi_K)
d = ta.sma(k, srsi_D)

srsi_exit_os = ta.crossover(k, srsi_os) or (k[1] < srsi_os and k > srsi_os and k > d)
srsi_exit_ob = ta.crossunder(k, srsi_ob) or (k[1] > srsi_ob and k < srsi_ob and k < d)

// ───────── SQUEEZE MOMENTUM (LazyBear) ─────────
bb_basis = ta.sma(close, sqz_bb_len)
bb_dev = sqz_bb_mult * ta.stdev(close, sqz_bb_len)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev

kc_ma = ta.sma(close, sqz_kc_len)
kc_rng = ta.sma(ta.tr, sqz_kc_len)
kc_upper = kc_ma + kc_rng * sqz_kc_mult
kc_lower = kc_ma - kc_rng * sqz_kc_mult

sqz_on = bb_lower > kc_lower and bb_upper < kc_upper
sqz_off = bb_lower < kc_lower and bb_upper > kc_upper
sqz_release = sqz_off and sqz_on[1]

mom_val = ta.linreg(close - math.avg(math.avg(ta.highest(high, sqz_kc_len), ta.lowest(low, sqz_kc_len)), ta.sma(close, sqz_kc_len)), sqz_kc_len, 0)

// ───────── PRICE ACTION — ENGULFING ─────────
bull_engulf = close > open and close[1] < open[1] and close > open[1] and open < close[1] and (close - open) > (open[1] - close[1]) * 1.2
bear_engulf = close < open and close[1] > open[1] and close < open[1] and open > close[1] and (open - close) > (close[1] - open[1]) * 1.2

// Strong close (close w górnej/dolnej 1/3 zakresu świecy)
candle_range = high - low
strong_bull_close = candle_range > 0 and (close - low) / candle_range > 0.66
strong_bear_close = candle_range > 0 and (high - close) / candle_range > 0.66

pa_bull = bull_engulf or strong_bull_close
pa_bear = bear_engulf or strong_bear_close

// ───────── KONFLUENCJE (6 kryteriów per kierunek) ─────────
// LONG
c1_long = bull_ma ? 1 : 0                   // MA alignment
c2_long = above_vwap ? 1 : 0                // Above VWAP
c3_long = in_long_fib ? 1 : 0               // In golden pocket
c4_long = srsi_exit_os ? 1 : 0              // Stoch RSI exit OS
c5_long = sqz_release and mom_val > 0 ? 1 : 0  // Squeeze release bullish
c6_long = pa_bull ? 1 : 0                   // PA bullish confirm

long_score = c1_long + c2_long + c3_long + c4_long + c5_long + c6_long

// SHORT
c1_short = bear_ma ? 1 : 0
c2_short = below_vwap ? 1 : 0
c3_short = in_short_fib ? 1 : 0
c4_short = srsi_exit_ob ? 1 : 0
c5_short = sqz_release and mom_val < 0 ? 1 : 0
c6_short = pa_bear ? 1 : 0

short_score = c1_short + c2_short + c3_short + c4_short + c5_short + c6_short

// ───────── SIGNALS ─────────
long_signal  = long_score >= min_confluences and long_score > short_score
short_signal = short_score >= min_confluences and short_score > long_score

// ───────── LEVELS ─────────
long_entry  = close
long_sl     = swing_low  * (1 - sl_buffer_pct / 100)
long_tp     = long_entry + (long_entry - long_sl) * rr_target

short_entry = close
short_sl    = swing_high * (1 + sl_buffer_pct / 100)
short_tp    = short_entry - (short_sl - short_entry) * rr_target

// ───────── VISUAL ─────────
plotshape(long_signal,  "LONG A",  shape.triangleup,   location.belowbar, color.new(color.lime, 0), size=size.small, text="A↑")
plotshape(short_signal, "SHORT A", shape.triangledown, location.abovebar, color.new(color.red, 0),  size=size.small, text="A↓")

// Tło przy aktywnym setupie
bgcolor(long_signal  ? color.new(color.green, 90) : na)
bgcolor(short_signal ? color.new(color.red,   90) : na)

// Tabela statusu
var table tbl = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.islast
    table.cell(tbl, 0, 0, "SETUP A",              text_color=color.white, bgcolor=color.new(color.blue, 50))
    table.cell(tbl, 1, 0, str.tostring(long_score) + "L / " + str.tostring(short_score) + "S", text_color=color.white, bgcolor=color.new(color.blue, 50))
    table.cell(tbl, 0, 1, "MA",       text_color=color.white)
    table.cell(tbl, 1, 1, bull_ma ? "BULL ✓" : bear_ma ? "BEAR ✓" : "—", text_color=bull_ma ? color.lime : bear_ma ? color.red : color.gray)
    table.cell(tbl, 0, 2, "VWAP",     text_color=color.white)
    table.cell(tbl, 1, 2, above_vwap ? "ABOVE" : "BELOW", text_color=above_vwap ? color.lime : color.red)
    table.cell(tbl, 0, 3, "Fib GP",   text_color=color.white)
    table.cell(tbl, 1, 3, in_long_fib ? "LONG ✓" : in_short_fib ? "SHORT ✓" : "—", text_color=(in_long_fib or in_short_fib) ? color.lime : color.gray)
    table.cell(tbl, 0, 4, "SRSI",     text_color=color.white)
    table.cell(tbl, 1, 4, srsi_exit_os ? "EXIT OS" : srsi_exit_ob ? "EXIT OB" : str.tostring(math.round(k, 1)), text_color=(srsi_exit_os or srsi_exit_ob) ? color.lime : color.gray)
    table.cell(tbl, 0, 5, "Squeeze",  text_color=color.white)
    table.cell(tbl, 1, 5, sqz_release ? "RELEASE" : sqz_on ? "ON" : "OFF", text_color=sqz_release ? color.lime : color.gray)
    table.cell(tbl, 0, 6, "PA",       text_color=color.white)
    table.cell(tbl, 1, 6, pa_bull ? "BULL" : pa_bear ? "BEAR" : "—", text_color=pa_bull ? color.lime : pa_bear ? color.red : color.gray)

// ───────── ALERTS (webhook JSON) ─────────
// LONG alert
if long_signal
    alert('{"secret":"DANIEL_TRADING_2026","setup":"A","direction":"LONG","ticker":"{{ticker}}","exchange":"{{exchange}}","timeframe":"{{interval}}","time":"{{time}}","price":' + str.tostring(close) + ',"entry":' + str.tostring(long_entry) + ',"sl":' + str.tostring(long_sl) + ',"tp":' + str.tostring(long_tp) + ',"rr":' + str.tostring(rr_target) + ',"confluences":' + str.tostring(long_score) + ',"max_confluences":6,"details":{"ma":' + str.tostring(c1_long) + ',"vwap":' + str.tostring(c2_long) + ',"fib":' + str.tostring(c3_long) + ',"srsi":' + str.tostring(c4_long) + ',"squeeze":' + str.tostring(c5_long) + ',"pa":' + str.tostring(c6_long) + '}}', alert.freq_once_per_bar_close)

// SHORT alert
if short_signal
    alert('{"secret":"DANIEL_TRADING_2026","setup":"A","direction":"SHORT","ticker":"{{ticker}}","exchange":"{{exchange}}","timeframe":"{{interval}}","time":"{{time}}","price":' + str.tostring(close) + ',"entry":' + str.tostring(short_entry) + ',"sl":' + str.tostring(short_sl) + ',"tp":' + str.tostring(short_tp) + ',"rr":' + str.tostring(rr_target) + ',"confluences":' + str.tostring(short_score) + ',"max_confluences":6,"details":{"ma":' + str.tostring(c1_short) + ',"vwap":' + str.tostring(c2_short) + ',"fib":' + str.tostring(c3_short) + ',"srsi":' + str.tostring(c4_short) + ',"squeeze":' + str.tostring(c5_short) + ',"pa":' + str.tostring(c6_short) + '}}', alert.freq_once_per_bar_close)

// Alertcondition (widoczne w menu "Create Alert")
alertcondition(long_signal,  "Setup A LONG",  "LONG setup wykryty")
alertcondition(short_signal, "Setup A SHORT", "SHORT setup wykryty")
