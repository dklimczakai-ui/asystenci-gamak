//@version=5
// ============================================================
// SETUP B — LIQUIDITY SWEEP REVERSAL (Daniel's trading system)
// ============================================================
// Wykrywa sweep equal highs/lows + CHoCH + divergence + rejection.
// Kierunek przeciwny do sweepa (smart money reversal).
// ============================================================

indicator("SETUP B — Liquidity Sweep [Daniel]", overlay=true, max_bars_back=500)

grp = "Parametry"
lookback_eq  = input.int(50, "Lookback equal highs/lows", minval=20, maxval=200, group=grp)
eq_tolerance = input.float(0.15, "Tolerancja equal %", step=0.05, group=grp)
rr_target    = input.float(3.0, "R/R target", minval=2.0, group=grp)
sl_buffer    = input.float(0.3, "SL buffer %", step=0.1, group=grp)
min_confluences = input.int(3, "Min konfluencji (z 4)", minval=2, maxval=4, group=grp)

// Equal highs/lows detection
swing_high = ta.highest(high, lookback_eq)
swing_low  = ta.lowest(low,  lookback_eq)

// Sweep = wick ponad equal high / pod equal low + close poniżej/powyżej
sweep_high = high > swing_high * (1 + eq_tolerance/100) and close < swing_high
sweep_low  = low  < swing_low  * (1 - eq_tolerance/100) and close > swing_low

// CHoCH — break struktury w przeciwnym kierunku (uproszczenie: 3 bar)
bos_down = low  < ta.lowest(low[1],  5) and close < ta.lowest(close[1], 3)
bos_up   = high > ta.highest(high[1], 5) and close > ta.highest(close[1], 3)

// Bearish sweep (high swept) → szukamy short → CHoCH down
// Bullish sweep (low swept)  → szukamy long  → CHoCH up
choch_short = bos_down and ta.barssince(sweep_high) < 5
choch_long  = bos_up   and ta.barssince(sweep_low)  < 5

// Stoch RSI divergence (uproszczenie)
rsi_val = ta.rsi(close, 14)
srsi = ta.stoch(rsi_val, rsi_val, rsi_val, 14)
k = ta.sma(srsi, 3)

// Bearish div: higher high in price, lower high in SRSI
bear_div = high > high[3] and k < k[3] and k > 60
bull_div = low  < low[3]  and k > k[3] and k < 40

// Rejection candle
bear_rejection = (high - close) / (high - low + 0.0001) > 0.6 and close < open
bull_rejection = (close - low) / (high - low + 0.0001) > 0.6 and close > open

// Konfluencje (4)
// LONG
c1_long = sweep_low ? 1 : 0
c2_long = choch_long ? 1 : 0
c3_long = bull_div ? 1 : 0
c4_long = bull_rejection ? 1 : 0
long_score = c1_long + c2_long + c3_long + c4_long

// SHORT
c1_short = sweep_high ? 1 : 0
c2_short = choch_short ? 1 : 0
c3_short = bear_div ? 1 : 0
c4_short = bear_rejection ? 1 : 0
short_score = c1_short + c2_short + c3_short + c4_short

long_signal  = long_score  >= min_confluences and long_score  > short_score
short_signal = short_score >= min_confluences and short_score > long_score

// Levels
long_sl  = swing_low  * (1 - sl_buffer/100)
long_tp  = close + (close - long_sl) * rr_target
short_sl = swing_high * (1 + sl_buffer/100)
short_tp = close - (short_sl - close) * rr_target

// Visuals
plotshape(long_signal,  "LONG B",  shape.labelup,   location.belowbar, color.new(color.lime, 0), text="B↑", textcolor=color.black, size=size.small)
plotshape(short_signal, "SHORT B", shape.labeldown, location.abovebar, color.new(color.red, 0),  text="B↓", textcolor=color.white, size=size.small)

// Swing lines
plot(swing_high, "EqHigh", color.new(color.gray, 50), 1, plot.style_circles)
plot(swing_low,  "EqLow",  color.new(color.gray, 50), 1, plot.style_circles)

// Alerts
if long_signal
    alert('{"secret":"DANIEL_TRADING_2026","setup":"B","direction":"LONG","ticker":"{{ticker}}","exchange":"{{exchange}}","timeframe":"{{interval}}","time":"{{time}}","price":' + str.tostring(close) + ',"entry":' + str.tostring(close) + ',"sl":' + str.tostring(long_sl) + ',"tp":' + str.tostring(long_tp) + ',"rr":' + str.tostring(rr_target) + ',"confluences":' + str.tostring(long_score) + ',"max_confluences":4,"details":{"sweep":' + str.tostring(c1_long) + ',"choch":' + str.tostring(c2_long) + ',"div":' + str.tostring(c3_long) + ',"rejection":' + str.tostring(c4_long) + '}}', alert.freq_once_per_bar_close)

if short_signal
    alert('{"secret":"DANIEL_TRADING_2026","setup":"B","direction":"SHORT","ticker":"{{ticker}}","exchange":"{{exchange}}","timeframe":"{{interval}}","time":"{{time}}","price":' + str.tostring(close) + ',"entry":' + str.tostring(close) + ',"sl":' + str.tostring(short_sl) + ',"tp":' + str.tostring(short_tp) + ',"rr":' + str.tostring(rr_target) + ',"confluences":' + str.tostring(short_score) + ',"max_confluences":4,"details":{"sweep":' + str.tostring(c1_short) + ',"choch":' + str.tostring(c2_short) + ',"div":' + str.tostring(c3_short) + ',"rejection":' + str.tostring(c4_short) + '}}', alert.freq_once_per_bar_close)

alertcondition(long_signal,  "Setup B LONG",  "B LONG")
alertcondition(short_signal, "Setup B SHORT", "B SHORT")
