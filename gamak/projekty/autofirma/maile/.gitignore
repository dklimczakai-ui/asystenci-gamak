# @mail v0.1 LOCAL — .gitignore
# Sekrety NIGDY do repo (R1: credential-protection.md).
# Daniel nie używa Git aktualnie, ale plik jest gotowy gdy projekt pójdzie pod kontrolę wersji.

# === Konfiguracja realna (z sekretami) ===
config/config.local.yaml

# === Folder z tokenami i App Passwordami ===
.credentials/

# === Logi sesji (zawierają id_maila, adresat, timestamp — bez treści, ale ostrożnie) ===
logs/

# === Audyty operacyjne (zawierają subject_reply / mailbox / gmail_id — R5 dane klientów) ===
audits/

# === Lokalne pliki testowe payload/response (R5: mogą zawierać body maili) ===
**/test_payload*.json
**/test_resp*.json

# === Wzorce na pliki z poświadczeniami (gdziekolwiek się pojawią) ===
gmail_token*
gmail_oauth_keys*
graph_client_secret*
graph_token*
imap_app_password*
*credentials*.json
!config/config.example.yaml

# === Generowane przez Pythona ===
__pycache__/
*.pyc
.venv/
venv/

# === System ===
.DS_Store
Thumbs.db
