#!/bin/bash
# COSTSEC pre-commit secret scanner
# Wymagane przez R1 (.claude/rules/credential-protection.md) i kandydat R15-R18 (ZASADY.md).
# Skanuje STAGED zmiany przed każdym commit. Exit 1 = blokuje commit.
#
# Aktywacja (raz, w roocie repo):
#   git config core.hooksPath gamak/projekty/autofirma/costsec/scripts/git-hooks
#
# Bypass awaryjny (TYLKO świadomie, np. dokumentacja patterny do skanu):
#   git commit --no-verify

set -u

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

EXIT_CODE=0
HITS=0

# Lista zatomatchowanych plików (staged, dodane lub zmodyfikowane)
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED" ]; then
  exit 0
fi

# Whitelist content scan: pliki dokumentacji COSTSEC z definicji opisują patterny sekretów (R18)
# Pomijamy CONTENT scan, ale FILENAME blacklist nadal działa.
is_costsec_doc() {
  case "$1" in
    */costsec/docs/*|*/costsec/scripts/git-hooks/*|*/costsec/audits/*|*/costsec/audits/*.md)
      return 0 ;;
    .claude/rules/*|*/.claude/rules/*)
      return 0 ;;
    *)
      return 1 ;;
  esac
}

# ---- 1. Filename blacklist (zawsze blokuje) ----
echo "[pre-commit] Filename blacklist scan..."
while IFS= read -r f; do
  case "$f" in
    *.env|.env|.env.local|.env.production)
      echo -e "${RED}BLOCKED:${NC} $f → .env nigdy nie idzie do repo (R1)"
      EXIT_CODE=1; HITS=$((HITS+1))
      ;;
    */settings.local.json|.claude/settings.local.json)
      echo -e "${RED}BLOCKED:${NC} $f → .claude/settings.local.json zawiera bash command history (R15)"
      EXIT_CODE=1; HITS=$((HITS+1))
      ;;
    *.pem|*.key|*.pfx|*_rsa|id_rsa|id_ed25519|id_ed25519_*)
      case "$f" in *.example|*.sample) ;; *)
        echo -e "${RED}BLOCKED:${NC} $f → klucz prywatny (R1)"
        EXIT_CODE=1; HITS=$((HITS+1))
        ;;
      esac
      ;;
    service-account*.json|credentials*.json|*-credentials.json)
      case "$f" in *.example|*.sample) ;; *)
        echo -e "${RED}BLOCKED:${NC} $f → service account JSON (R1)"
        EXIT_CODE=1; HITS=$((HITS+1))
        ;;
      esac
      ;;
    *_real.json|*-real.json)
      echo -e "${RED}BLOCKED:${NC} $f → konwencja '_real' = real data, gitignored (R16)"
      EXIT_CODE=1; HITS=$((HITS+1))
      ;;
  esac
done <<< "$STAGED"

# ---- 2. Content scan — wzorce sekretów (z whitelistą docs COSTSEC) ----
echo "[pre-commit] Content secret scan..."

# Filtruj staged files — pomiń dokumentację COSTSEC z content scanu (R18 — opisy strukturalne dozwolone)
CONTENT_SCAN_FILES=""
SKIPPED_DOCS=""
while IFS= read -r f; do
  if is_costsec_doc "$f"; then
    SKIPPED_DOCS="$SKIPPED_DOCS $f"
  else
    CONTENT_SCAN_FILES="$CONTENT_SCAN_FILES $f"
  fi
done <<< "$STAGED"

if [ -n "$SKIPPED_DOCS" ]; then
  echo "  → skipping content scan dla docs COSTSEC (R18):"
  for f in $SKIPPED_DOCS; do echo "      $f"; done
fi

# Funkcja: skanuje diff dla konkretnych plików
scan_pattern() {
  local pat="$1"
  local mode="$2"  # E (regex) lub F (fixed string)
  if [ -z "$CONTENT_SCAN_FILES" ]; then
    return 0
  fi
  local hit
  hit=$(git diff --cached -U0 -- $CONTENT_SCAN_FILES | grep -nE "^\+" | grep -n${mode} "$pat" || true)
  if [ -n "$hit" ]; then
    echo "$hit"
    return 1
  fi
  return 0
}

PATTERNS_SECRETS=(
  'AKIA[0-9A-Z]{16}'
  'sk-ant-api[0-9]{2}-[a-zA-Z0-9_\-]{20,}'
  'sk-[a-zA-Z0-9]{48}'
  'AIzaSy[A-Za-z0-9_\-]{33}'
  'ghp_[A-Za-z0-9]{36}'
  'github_pat_[A-Za-z0-9_]{82}'
  'sk_live_[A-Za-z0-9]{24,}'
  'pk_live_[A-Za-z0-9]{24,}'
  'xox[bp]-[0-9]+-[0-9]+-[a-zA-Z0-9-]+'
  'eyJ[A-Za-z0-9_\-]{20,}\.[A-Za-z0-9_\-]{20,}\.[A-Za-z0-9_\-]{20,}'
  '[0-9]{8,10}:AA[A-Za-z0-9_\-]{33}'
  'EAA[A-Za-z0-9]{50,}'
)

for pat in "${PATTERNS_SECRETS[@]}"; do
  HIT=$(scan_pattern "$pat" "E")
  if [ -n "$HIT" ]; then
    echo -e "${RED}BLOCKED:${NC} pattern [$pat] znaleziony w staged diff:"
    echo "$HIT" | head -5
    EXIT_CODE=1; HITS=$((HITS+1))
  fi
done

# ---- 3. R1 incident-specific patterns (post-rotation, ale wciąż blokujemy poza docs) ----
echo "[pre-commit] R1 incident patterns scan..."
INCIDENT_PATTERNS=(
  'Pomidor01'
  '8693260455:AAH'
  'AAHhtVNpl1G'
)
for pat in "${INCIDENT_PATTERNS[@]}"; do
  HIT=$(scan_pattern "$pat" "F")
  if [ -n "$HIT" ]; then
    echo -e "${YELLOW}WARN:${NC} pattern [$pat] (R1 incident, post-rotation) znaleziony:"
    echo "$HIT" | head -3
    EXIT_CODE=1; HITS=$((HITS+1))
  fi
done

# ---- 4. PII PL — telefon, adres pełen ----
echo "[pre-commit] PII PL scan..."
if [ -n "$CONTENT_SCAN_FILES" ]; then
  HIT_PHONE=$(git diff --cached -U0 -- $CONTENT_SCAN_FILES | grep -nE "^\+" | grep -nE "\+48[ \-]?[0-9]{3}[ \-]?[0-9]{3}[ \-]?[0-9]{3}" || true)
  if [ -n "$HIT_PHONE" ]; then
    echo -e "${YELLOW}WARN:${NC} numer telefonu PL (\+48 NNN NNN NNN) w staged:"
    echo "$HIT_PHONE" | head -3
    echo "    → jeśli to placeholder (\+48 XXX XXX XXX) — OK, jeśli realny — BLOKADA (R5)"
    echo "    → użyj 'git commit --no-verify' tylko jeśli świadomie placeholder"
    EXIT_CODE=1; HITS=$((HITS+1))
  fi
fi

# ---- Podsumowanie ----
echo ""
if [ $EXIT_CODE -eq 0 ]; then
  echo -e "${GREEN}[pre-commit] PASS${NC} — 0 trafień, commit dozwolony."
else
  echo -e "${RED}[pre-commit] FAIL${NC} — $HITS trafień, commit ZABLOKOWANY."
  echo ""
  echo "Co zrobić:"
  echo "  1. Sprawdź każde trafienie powyżej."
  echo "  2. Jeśli to realny sekret/PII — usuń ze staged, dodaj do .gitignore, rotuj."
  echo "  3. Jeśli to placeholder/dokumentacja patterny — 'git commit --no-verify' świadomie."
  echo "  4. Wpis do CHANGELOG.md jeśli używasz --no-verify (R6 dług bez daty końca = STOP)."
fi

exit $EXIT_CODE
