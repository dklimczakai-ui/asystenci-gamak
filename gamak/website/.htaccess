# ============================================
# GAMAK.EU - Static HTML Configuration
# Updated: 2026-03-02
# ============================================

# LiteSpeed Cache - DISABLE (required for static HTML site)
<IfModule LiteSpeed>
CacheLookup off
</IfModule>

RewriteEngine On
DirectoryIndex index.html

# ============================================
# BLOG — explicit rules (no -f check, bypasses LiteSpeed stat cache)
# ============================================
RewriteRule ^blog/?$ blog.html [L]
RewriteRule ^blog/lodowisko-dla-gminy-koszt-budowa/?$ blog/lodowisko-dla-gminy-koszt-budowa.html [L]
RewriteRule ^blog/lodowisko-syntetyczne-vs-tradycyjne/?$ blog/lodowisko-syntetyczne-vs-tradycyjne.html [L]
RewriteRule ^blog/dofinansowanie-infrastruktura-sportowa-2026/?$ blog/dofinansowanie-infrastruktura-sportowa-2026.html [L]
RewriteRule ^blog/boisko-lodowisko-2w1-obiekt-caloroczny/?$ blog/boisko-lodowisko-2w1-obiekt-caloroczny.html [L]
RewriteRule ^blog/nawierzchnie-sportowe-dla-samorzadow/?$ blog/nawierzchnie-sportowe-dla-samorzadow.html [L]
RewriteRule ^blog/jak-wybrac-wykonawce-infrastruktury-sportowej/?$ blog/jak-wybrac-wykonawce-infrastruktury-sportowej.html [L]

# ============================================
# CLEAN URLs (extensionless)
# ============================================

# Remove .html extension from URLs (301 redirect)
# Special: index.html -> directory root
RewriteCond %{THE_REQUEST} \s/+en/index\.html[\s?] [NC]
RewriteRule ^ /en/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^ / [R=301,L]

# Generic: any .html -> clean URL
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Remove trailing slashes (prevents 500 errors)
# Exception: real directories (like /blog/, /en/)
RewriteCond %{REQUEST_URI} !^/blog/ [NC]
RewriteCond %{REQUEST_URI} !^/en/ [NC]
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Serve wp-content images from backup folder
RewriteRule ^wp-content/(.*)$ _wp_backup/wp-content/$1 [L]

# Internally serve .html files for clean URLs (root level pages)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

