# -----------------------------------------------------------------------------
# 7) SPECYFICZNE PLIKI W TYM REPO
# -----------------------------------------------------------------------------

# Pliki które wykrył skan jako wrażliwe (21.04 i 04.05.2026)
client_secret_2_74379878705-1ib0cgkddcjlbdo94v3ij65u464lir7j.apps.googleusercontent.com.json
trading/skaner/lambda/.env
trading/skaner/.env
trading/narzedzia/webhooks/.env
beauty/.env

